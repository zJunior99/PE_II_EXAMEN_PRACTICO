# Ejemplo de variables de entorno para Supabase
# Rellena con tus valores reales antes de usar.

# Supabase - cliente (uso en frontend o clientes públicos)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Supabase - servidor (opcional, secreto)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base de datos Postgres (string de conexión)
DATABASE_URL=postgres://user:password@db.host:5432/dbname

# Configuración de la app
APP_ENV=development
APP_DEBUG=true

# Opcional: URL de callback para autenticación (si la usas)
SUPABASE_AUTH_CALLBACK_URL=http://localhost:8000/auth/callback
